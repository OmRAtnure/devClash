PORT=5000
NODE_ENV=development

# MongoDB (local)
MONGODB_URI=mongodb://localhost:27017/hirex

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# Python FastAPI ML Service
FASTAPI_URL=http://localhost:8000

# SMTP Email (for OTP) - use Gmail App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
FROM_EMAIL=noreply@hirex.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# OTP expiry in minutes
OTP_EXPIRY_MINUTES=10

# OAuth Credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
SESSION_SECRET=your_session_secret_for_oauth

# DigiLocker API (https://partners.digitallocker.gov.in)
DIGILOCKER_CLIENT_ID=your_digilocker_client_id
DIGILOCKER_CLIENT_SECRET=your_digilocker_client_secret
DIGILOCKER_REDIRECT_URI=http://localhost:5000/api/auth/digilocker/callback
