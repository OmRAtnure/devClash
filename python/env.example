# Qdrant Cloud
QDRANT_URL=https://your-cluster-url.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=hirex_faces

# Face Identity Threshold (Cosine Similarity)
# > 0.60 = same person | < 0.60 = different person
COSINE_THRESHOLD=0.60

# Anti-spoofing model directory (relative to python/)
SPOOF_MODEL_DIR=./models/silent_face
